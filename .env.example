# Copy this to .env in the backend/ directory for local development.
# Never commit .env to version control.

# Django
SECRET_KEY=dev-secret-key-change-in-production-abc123
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Leave unset to use SQLite (default for local dev)
# DATABASE_URL=postgresql://user:password@localhost:5432/breathe_esg

# CORS — add your frontend origin if needed
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com

# Demo user passwords (used by: python manage.py create_demo_data)
DEMO_ANALYST_PASSWORD=analyst123
DEMO_ADMIN_PASSWORD=admin123
